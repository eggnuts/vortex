<script>
    const profilesData = {
        eggnuts: {
            name: 'eggnuts',
            role: 'Кодер проекта.',
            desc: 'Написал всю веб-часть (этот сайт) и сборку внутренних плагинов. Ежедневно занимается отслеживанием, исправлением багов ядра и закрытием вопросов игроков.',
            ds: '_eggnuts_',
            yt: 'https://www.youtube.com/@eggnuts14',
            skin: 'eggnuts',
            hideSocials: false
        },
        prorok_admin: {
            name: 'Prorokvk',
            role: 'Гл. Администратор / Контент-мейкер',
            desc: 'Идейный вдохновитель VORTEX. Совмещает администрирование с ведением медиа-ресурсов. Берёт на себя все финансовые обязательства по аренде мощностей хостинга, а также активно пиарит и продвигает проект.',
            skin: 'Prorokvk',
            hideSocials: true
        }
    };

    const modal = document.getElementById('profile-modal');
    const modalWindow = document.getElementById('modal-window-box');
    const jokeModal = document.getElementById('joke-pay-modal');
    const receiptOverlay = document.getElementById('receipt-modal-overlay');
    const discordRedirectModal = document.getElementById('discord-redirect-modal');

    function toggleRule(element) {
        element.classList.toggle('expanded');
    }

    // Изменение: в переменные добавлено автоматическое переключение акцентного цвета сетки
    function showPage(pageId) {
        document.querySelectorAll('.page').forEach(page => page.classList.remove('active-page'));
        document.querySelectorAll('nav a').forEach(link => link.classList.remove('active'));

        const targetPage = document.getElementById(`page-${pageId}`);
        const targetLink = document.getElementById(`nav-${pageId}`);
        
        if (targetPage) targetPage.classList.add('active-page');
        if (targetLink) targetLink.classList.add('active');

        document.body.className = `theme-${pageId}`;

        if (targetPage) {
            targetPage.querySelectorAll('.animate-fade-up').forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight; 
                el.style.animation = '';
            });
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function openProfile(id) {
        const data = profilesData[id];
        if (!data) return;

        document.getElementById('modal-name').innerText = data.name;
        document.getElementById('modal-role').innerText = data.role;
        document.getElementById('modal-desc').innerText = data.desc;
        document.getElementById('modal-avatar').src = `https://minotar.net/armor/bust/${data.skin}/120.png`;

        if (data.hideSocials) {
            modalWindow.classList.add('no-socials');
        } else {
            modalWindow.classList.remove('no-socials');
            document.getElementById('modal-ds-link').innerText = `💬 ${data.ds}`;
            document.getElementById('modal-yt-link').href = data.yt;
        }
        modal.classList.add('open');
    }

    function closeProfile() { modal.classList.remove('open'); }

    function copyIp() {
        const ipText = document.getElementById('server-ip').innerText;
        navigator.clipboard.writeText(ipText).then(() => {
            const toast = document.getElementById('ip-toast');
            toast.classList.add('show');
            setTimeout(() => { toast.classList.remove('show'); }, 2000);
        });
    }

    let currentItemName = "";
    let currentItemCost = "";

    function payWithJoke(itemName, cost) {
        currentItemName = itemName;
        currentItemCost = cost;
        document.getElementById('joke-item-name').innerText = itemName;
        document.getElementById('joke-item-cost').innerText = cost;
        document.getElementById('pay-ign').value = "";
        hideError();
        document.getElementById('pay-form-content').style.display = "block";
        document.getElementById('cosmic-loader').style.display = "none";
        jokeModal.classList.add('open');
    }

    function closeJokePay() { jokeModal.classList.remove('open'); }
    function hideError() { document.getElementById('pay-error-display').style.display = "none"; }
    
    function showError(text) {
        const errBox = document.getElementById('pay-error-display');
        document.getElementById('pay-error-msg').innerText = text;
        errBox.style.display = "flex";
        errBox.style.animation = 'none';
        errBox.offsetHeight; 
        errBox.style.animation = 'shake 0.4s ease-in-out';
    }

    function processPayment(method) {
        hideError();
        const nickname = document.getElementById('pay-ign').value.trim();
        if (!nickname) { showError("Укажите ваш никнейм перед выбором способа оплаты!"); return; }
        if (/[а-яёА-ЯЁ]/.test(nickname)) { showError("В нике не должно быть русских букв"); return; }
        if (method === 'mom') { showError("Верни маме карту"); return; } 
        if (method === 'pigeon') { showError("Почтовые голуби задерживаются из-за плохой погоды."); return; } 
        
        if (method === 'sbp') {
            document.getElementById('pay-form-content').style.display = "none";
            document.getElementById('cosmic-loader').style.display = "flex";
            let dotsCount = 0;
            const loaderTextEl = document.getElementById('loader-text');
            const dotsInterval = setInterval(() => {
                dotsCount = (dotsCount + 1) % 4;
                let dotsStr = "";
                for(let i=0; i<dotsCount; i++) dotsStr += ".";
                loaderTextEl.innerText = "Связь с космосом" + dotsStr;
            }, 1000);
            
            setTimeout(() => {
                clearInterval(dotsInterval);
                closeJokePay();
                generatePaperReceipt(nickname);
            }, 3000);
        }
    }

    function generatePaperReceipt(nickname) {
        const now = new Date();
        const pad = (num) => String(num).padStart(2, '0');
        const dateTimeStr = `${pad(now.getDate())}.${pad(now.getMonth() + 1)}.${now.getFullYear()} ${pad(now.getHours())}:${pad(now.getMinutes())}`;
        const transactionID = "VRTX-" + Math.floor(100000 + Math.random() * 900000);

        document.getElementById('paper-receipt-text').innerText = `
=========================================
ЧЕК: №${Math.floor(1000 + Math.random()*9000)}     
Дата: ${dateTimeStr}
ТРАНЗАКЦИЯ: ${transactionID}
ПОКУПАТЕЛЬ: ${nickname}
-----------------------------------------
Товар: ${currentItemName}
Цена: ${currentItemCost}
Статус: Выдано eggnuts
-----------------------------------------
ИТОГ К ОПЛАТЕ: ${currentItemCost}
СПОСОБ ОПЛАТЫ: СБП

⚠️ ВНИМАНИЕ ИГРОКУ:
Товар зачислен! Если донат не пришел в
течение 5 минут, пожалуйста, не бейте
Дмитрия и напишите нам в техподдержку.
=========================================
         СПАСИБО ЗА ПОКУПКУ,
         Удачи на VortexSMP!
=========================================`;
        receiptOverlay.classList.add('open');
    }

    function closeReceiptModal() {
        receiptOverlay.classList.remove('open');
        if (currentItemName === "Кастом Донат" || currentItemName === "Кастомный Титул") {
            setTimeout(() => {
                document.getElementById('redirect-item-name').innerText = currentItemName;
                discordRedirectModal.classList.add('open');
                window.open("https://discord.gg/pMHbxtnEZx", "_blank");
            }, 400);
        }
    }

    function finishDiscordRedirect() { discordRedirectModal.classList.remove('open'); }

    window.addEventListener('click', function(e) {
        if (e.target === modal) closeProfile();
        if (e.target === jokeModal) closeJokePay();
        if (e.target === receiptOverlay) closeReceiptModal();
        if (e.target === discordRedirectModal) finishDiscordRedirect();
    });

    // ═══════════════════════════════════════════════
    //  ЖИВОЙ СТАТУС СЕРВЕРА — mcsrvstat.us
    // ═══════════════════════════════════════════════
    const MC_HOST = 'b2.qwertyx.host';
    const MC_PORT = 28782;
    const REFRESH_INTERVAL = 60000;

    const pingDotSpan = document.querySelector('.status-ping-dot span');
    const pingDotCore = document.querySelector('.status-core-dot');
    const statusLabel = document.getElementById('server-status-label');
    const counterEl   = document.getElementById('online-counter');

    function setOffline() {
        pingDotSpan.style.background = '#ef4444';
        pingDotCore.style.background = '#ef4444';
        statusLabel.textContent = 'Сервер недоступен';
        counterEl.textContent = '0 / ?';
        counterEl.style.color = '#ef4444';
        counterEl.style.borderColor = 'rgba(239,68,68,0.2)';
        counterEl.style.background  = 'rgba(239,68,68,0.03)';
    }

    async function fetchServerStatus() {
        try {
            const res = await fetch(`https://api.mcsrvstat.us/3/${MC_HOST}:${MC_PORT}`, { signal: AbortSignal.timeout(8000) });
            if (!res.ok) throw new Error('bad response');
            const data = await res.json();

            if (!data.online) { setOffline(); return; }

            pingDotSpan.style.background = '#10b981';
            pingDotCore.style.background = '#10b981';
            statusLabel.textContent = 'Сервер включен';

            const online = data.players?.online ?? 0;
            const max    = data.players?.max    ?? '?';
            counterEl.textContent = `${online} / ${max}`;
            counterEl.style.color = '#10b981';
            counterEl.style.borderColor = 'rgba(16,185,129,0.2)';
            counterEl.style.background  = 'rgba(16,185,129,0.03)';

        } catch (e) {
            setOffline();
        }
    }

    fetchServerStatus();
    setInterval(fetchServerStatus, REFRESH_INTERVAL);

    function recalcVortex() {
        const input = document.getElementById('vortex-count');
        let count = parseInt(input.value);
        if (isNaN(count) || count < 1) count = 1;
        const finalPrice = count + " ₽";
        document.getElementById('vortex-price-display').innerText = finalPrice;
        document.getElementById('vortex-buy-btn').setAttribute('onclick', `payWithJoke('Вортексы', '${finalPrice}')`);
    }
</script>

</body>
</html>
