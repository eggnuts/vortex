<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VORTEX | Official Minecraft Project</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=Unbounded:wght@400;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #020406;
            --bg-gradient: radial-gradient(circle at 50% 50%, #1f2937 0%, #111827 50%, #000000 100%);
            --panel: rgba(25, 30, 41, 0.65);
            --acc: #facc15;
            --acc-glow: rgba(250, 204, 21, 0.25);
            --red-acc: #ef4444;
            --red-glow: rgba(239, 68, 68, 0.15);
            --text-main: #ffffff;
            --text-muted: #94a3b8;
            --border: rgba(55, 65, 81, 0.6);
            
            /* Динамический базовый цвет для нашей переливашки */
            --ambient: #facc15;
            
            transition: --acc 0.5s ease, --acc-glow 0.5s ease, --ambient 0.5s ease;
        }

        /* ПЛАВНЫЕ ПЕРЕЛИВЫ С УЧЕТОМ АКТИВНОЙ ВКЛАДКИ */
        body.theme-main {
            --acc: #facc15;
            --ambient: #facc15;
            --acc-glow: rgba(250, 204, 21, 0.2);
            --bg-gradient: radial-gradient(circle at 20% 30%, rgba(250, 204, 21, 0.05) 0%, #374151 35%, #1f2937 70%, #000000 100%);
        }
        body.theme-rules {
            --acc: #ef4444;
            --ambient: #ef4444;
            --acc-glow: rgba(239, 68, 68, 0.25);
            --bg-gradient: radial-gradient(circle at 50% 30%, rgba(239, 68, 68, 0.06) 0%, #4b5563 30%, #111827 75%, #000000 100%);
        }
        body.theme-donate {
            --acc: #a855f7;
            --ambient: #a855f7;
            --acc-glow: rgba(168, 85, 247, 0.2);
            --bg-gradient: radial-gradient(circle at 80% 40%, rgba(168, 85, 247, 0.05) 0%, #374151 40%, #111827 70%, #000000 100%);
        }
        body.theme-contacts {
            --acc: #10b981;
            --ambient: #10b981;
            --acc-glow: rgba(16, 185, 129, 0.2);
            --bg-gradient: radial-gradient(circle at 30% 60%, rgba(16, 185, 129, 0.05) 0%, #4b5563 35%, #1f2937 75%, #000000 100%);
        }

        /* КАСТОМНЫЙ СКРОЛЛБАР СТРАНИЦЫ */
        ::-webkit-scrollbar {
            width: 10px;
            background-color: var(--bg);
        }
        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.01);
            border-left: 1px solid var(--border);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--acc);
            border-radius: 10px;
            border: 2px solid var(--bg);
            box-shadow: 0 0 10px var(--acc-glow);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }

        body {
            background-color: var(--bg);
            color: var(--text-main);
            font-family: 'Space Grotesk', sans-serif;
            margin: 0;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* ПЕРЕЛИВАЮЩЕЕСЯ ПЯТНО НА СЕТКЕ (ЗАМЕНА БЕЛОГО НА ЦВЕТ ВКЛАДКИ) */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: 
                linear-gradient(var(--ambient) 1px, transparent 1px),
                linear-gradient(90deg, var(--ambient) 1px, transparent 1px);
            background-size: 60px 60px;
            background-position: center;
            mask-image: radial-gradient(circle at 50% 50%, black 25%, transparent 75%);
            -webkit-mask-image: radial-gradient(circle at 50% 50%, black 25%, transparent 75%);
            z-index: -2;
            pointer-events: none;
            opacity: 0.12; /* Подкрути прозрачность под себя, чтобы сетка не била по глазам */
            animation: cosmicHue 8s linear infinite;
        }

        /* АНИМАЦИЯ ПЕРЕЛИВАШКИ ДЛЯ КУЛИСНОГО ФОНА */
        @keyframes cosmicHue {
            0% { filter: hue-rotate(0deg); }
            100% { filter: hue-rotate(360deg); }
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border-bottom: 1px solid var(--border);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-family: 'Unbounded', sans-serif;
            font-size: 24px;
            font-weight: 900;
            color: #fff;
            letter-spacing: 2px;
            cursor: pointer;
        }

        .logo span {
            color: var(--acc);
            text-shadow: 0 0 15px var(--acc-glow);
            transition: color 0.5s ease;
        }

        nav {
            display: flex;
            gap: 35px;
        }

        nav a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1.5px;
            transition: all 0.4s ease;
            position: relative;
            padding: 5px 0;
            cursor: pointer;
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--acc);
            transition: width 0.3s ease, background 0.5s ease;
            box-shadow: 0 0 8px var(--acc);
        }

        nav a:hover::after, nav a.active::after { width: 100%; }
        nav a:hover, nav a.active { color: #fff; }

        .page {
            display: none;
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            padding-top: 140px;
            padding-bottom: 80px;
        }

        .page.active-page {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

        .active-page .animate-fade-up {
            animation: fadeUpIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }

        .active-page .delay-1 { animation-delay: 0.1s; }
        .active-page .delay-2 { animation-delay: 0.2s; }
        .active-page .delay-3 { animation-delay: 0.3s; }
        .active-page .delay-4 { animation-delay: 0.4s; }

        @keyframes fadeUpIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hero {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding-bottom: 40px;
        }

        .hero-badge {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 8px 20px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-bottom: 30px;
        }

        .hero h1 {
            font-family: 'Unbounded', sans-serif;
            font-size: 72px;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 25px;
            letter-spacing: -2px;
            background: linear-gradient(180deg, #fff 40%, #a1a1aa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero h1 span {
            color: transparent;
            -webkit-text-stroke: 1.5px var(--acc);
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 20px var(--acc-glow));
            transition: -webkit-text-stroke 0.5s ease, filter 0.5s ease;
        }

        .hero p {
            color: var(--text-muted);
            font-size: 20px;
            max-width: 650px;
            line-height: 1.6;
            margin-bottom: 45px;
        }

        .widgets-wrapper {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .version-widget, .ip-widget {
            display: flex;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 15px 35px;
            align-items: center;
            gap: 15px;
            backdrop-filter: blur(15px);
        }

        .ip-widget {
            cursor: pointer;
            position: relative;
            transition: border-color 0.3s ease, transform 0.2s;
        }

        .ip-widget:hover {
            border-color: var(--acc);
            transform: scale(1.02);
        }

        .v-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; }
        .v-value { font-family: 'Unbounded', sans-serif; font-size: 18px; font-weight: 900; color: var(--acc); transition: color 0.5s ease; }

        .copy-toast {
            position: absolute;
            bottom: -45px;
            left: 50%;
            transform: translateX(-50%) translateY(10px);
            background: #10b981;
            color: #fff;
            padding: 6px 16px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 700;
            font-family: 'Unbounded', sans-serif;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .copy-toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        .sections-container {
            padding: 40px 10%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 32px;
            margin-bottom: 50px;
            position: relative;
            padding-left: 20px;
        }

        .section-title::before {
            content: '';
            position: absolute;
            left: 0; top: 20%; height: 60%; width: 5px;
            background: var(--acc);
            border-radius: 10px;
            box-shadow: 0 0 12px var(--acc);
            transition: background 0.5s ease, box-shadow 0.5s ease;
        }

        .grid-features {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-bottom: 80px;
        }

        .feat-card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 28px;
            padding: 40px;
            backdrop-filter: blur(15px);
            transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .feat-card:hover {
            border-color: var(--acc);
            transform: translateY(-5px);
            box-shadow: 0 15px 30px var(--acc-glow);
        }

        .feat-icon-wrapper {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            font-size: 24px;
        }

        .feat-card h3 { font-family: 'Unbounded', sans-serif; font-size: 18px; margin-bottom: 15px; }
        .feat-card p { color: var(--text-muted); font-size: 15px; line-height: 1.7; }

        .rules-grid-layout {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            align-items: start;
        }

        .rules-column-group {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .rule-category-title { 
            font-family: 'Unbounded', sans-serif; 
            font-size: 20px; 
            color: #fff; 
            margin: 25px 0 10px 0; 
            border-bottom: 1px solid rgba(255,255,255,0.08); 
            padding-bottom: 8px;
        }

        .rule-block { 
            background: var(--panel); 
            border: 1px solid var(--border); 
            border-radius: 16px; 
            padding: 20px 24px; 
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); 
            backdrop-filter: blur(15px); 
            overflow: hidden;
        }

        .rule-block:hover { 
            border-color: var(--acc); 
            box-shadow: 0 8px 20px var(--acc-glow);
        }

        .rule-block-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .rule-block h3 { 
            font-family: 'Unbounded', sans-serif; 
            font-size: 14px; 
            color: #fff; 
            display: flex; 
            gap: 12px; 
            align-items: center; 
        }
        
        .rule-block h3 span { 
            color: var(--acc); 
            font-weight: 900;
            transition: color 0.5s ease;
        }

        .rule-chevron {
            font-size: 12px;
            color: var(--text-muted);
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .rule-block-content {
            max-height: 0;
            opacity: 0;
            visibility: hidden;
            transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease, margin-top 0.3s ease;
        }

        .rule-block.expanded {
            border-color: var(--acc);
            background: rgba(31, 41, 55, 0.8);
        }

        .rule-block.expanded .rule-chevron {
            transform: rotate(180deg);
            color: var(--acc);
        }

        .rule-block.expanded .rule-block-content {
            max-height: 500px; 
            opacity: 1;
            visibility: visible;
            margin-top: 15px;
            padding-top: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .rule-block p { color: var(--text-main); font-size: 14px; line-height: 1.6; }
        .rule-sub-list { list-style: none; margin-top: 10px; padding-left: 15px; border-left: 2px solid var(--acc); }
        .rule-sub-list li { font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
        .rule-sub-list li b { color: #10b981; }

        .server-status-box { background: rgba(15, 23, 42, 0.6); border: 1px solid var(--border); border-radius: 32px; padding: 35px; margin-bottom: 80px; backdrop-filter: blur(20px); }
        .status-split-container { display: grid; grid-template-columns: 1fr 1fr; gap: 35px; margin-bottom: 35px; }
        .status-avatar-img { width: 100%; height: 250px; object-fit: cover; border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.05); background: #000; }
        .status-data-side { display: flex; flex-direction: column; justify-content: center; gap: 20px; }
        .status-bar-mini { background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); padding: 24px 30px; border-radius: 20px; display: flex; justify-content: space-between; align-items: center; }
        .status-info-row { display: flex; align-items: center; gap: 15px; }
        .status-ping-dot { position: relative; display: flex; width: 10px; height: 10px; }
        .status-ping-dot span { position: absolute; width: 100%; height: 100%; background: #10b981; border-radius: 50%; animation: ping 1.5s infinite; }
        .status-core-dot { width: 10px; height: 10px; background: #10b981; border-radius: 50%; }
        .status-lbl { font-weight: 700; font-size: 16px; color: #fff; }
        .status-online-number { font-family: 'Unbounded', sans-serif; color: var(--acc); font-size: 20px; font-weight: 900; background: rgba(255, 255, 255, 0.02); padding: 6px 18px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.08); transition: color 0.5s ease; }
        .players-list-block { background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(255,255,255,0.02); border-radius: 20px; padding: 25px; }
        .players-list-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 15px; }
        .players-list-title { font-family: 'Unbounded', sans-serif; font-size: 13px; color: #fff; letter-spacing: 1px; text-transform: uppercase; }
        .players-list-counter { font-family: 'Unbounded', sans-serif; font-size: 12px; color: var(--acc); background: rgba(255, 255, 255, 0.04); padding: 4px 12px; border-radius: 8px; font-weight: 700; }
        .players-heads-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 15px; }
        .player-head-tag { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 10px 16px; border-radius: 14px; font-size: 14px; font-weight: 700; display: flex; align-items: center; gap: 12px; }
        .player-mini-avatar { width: 24px; height: 24px; background-size: cover; background-position: center; border-radius: 4px; }
        
        .sub-section-header { font-family: 'Unbounded', sans-serif; font-size: 24px; text-align: center; margin-bottom: 40px; display: flex; justify-content: center; align-items: center; gap: 15px; margin-top: 50px; }
        .media-grid { display: flex; flex-wrap: wrap; gap: 30px; margin-bottom: 60px; justify-content: center; }
        .media-card { background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 24px; padding: 35px 24px 28px 24px; text-align: center; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); position: relative; width: 280px; backdrop-filter: blur(15px); }
        .media-card.admin-type:hover { border-color: var(--acc); box-shadow: 0 20px 40px var(--acc-glow); transform: translateY(-8px); }
        .skin-avatar-container { height: 130px; width: 130px; margin: 0 auto 20px auto; display: flex; align-items: center; justify-content: center; }
        .skin-avatar-img { width: 100px; height: 100px; object-fit: contain; image-rendering: pixelated; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5)); transition: transform 0.4s ease; }
        .media-card:hover .skin-avatar-img { transform: scale(1.15) rotate(5deg); }
        .media-platform-icon { font-size: 22px; margin-bottom: 12px; color: var(--acc); }
        .media-name { font-family: 'Unbounded', sans-serif; font-size: 20px; font-weight: 900; margin-bottom: 6px; }
        .media-card.admin-type:hover .media-name { color: var(--acc); }
        .media-role { color: var(--text-muted); font-size: 13px; margin-bottom: 15px; min-height: 44px; display: flex; align-items: center; justify-content: center; }
        .media-handle { display: inline-block; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.08); color: #fef08a; padding: 5px 16px; border-radius: 100px; font-size: 12px; font-family: monospace; margin-bottom: 25px; }
        .btn-more { width: 100%; background: transparent; border: 1px solid rgba(255,255,255,0.05); color: var(--text-muted); padding: 14px; border-radius: 14px; font-family: 'Unbounded', sans-serif; font-size: 11px; font-weight: 700; cursor: pointer; transition: 0.3s; text-decoration: none; display: block; }
        .media-card.admin-type:hover .btn-more { border-color: var(--acc); color: #fff; background: rgba(255, 255, 255, 0.02); }

        .promo-banner { background: linear-gradient(90deg, rgba(168, 85, 247, 0.15) 0%, rgba(11, 15, 23, 0.6) 100%); border: 1px solid rgba(168, 85, 247, 0.4); border-radius: 20px; padding: 20px 30px; margin-bottom: 35px; display: flex; align-items: center; gap: 20px; backdrop-filter: blur(10px); }
        .promo-icon { font-size: 28px; }
        .promo-text h4 { font-family: 'Unbounded', sans-serif; font-size: 16px; color: #fff; margin-bottom: 4px; }
        .promo-text p { color: var(--text-muted); font-size: 14px; }

        .donate-grid-fixed { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; max-width: 1300px; margin: 0 auto; width: 100%; }
        .donate-card-modern { background: var(--panel); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; padding: 35px 25px; text-align: center; transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1); display: flex; flex-direction: column; justify-content: space-between; background: linear-gradient(180deg, rgba(255, 255, 255, 0.01) 0%, rgba(11, 15, 23, 0.5) 100%); backdrop-filter: blur(15px); }
        .donate-card-modern:hover { border-color: var(--acc); transform: translateY(-5px); box-shadow: 0 15px 35px var(--acc-glow); }
        .donate-card-modern.premium-style { border-color: rgba(255, 255, 255, 0.15); background: linear-gradient(180deg, rgba(255, 255, 255, 0.02) 0%, rgba(11, 15, 23, 0.8) 100%); }
        .donate-card-modern.premium-style:hover { border-color: var(--acc); box-shadow: 0 15px 35px var(--acc-glow); }
        .donate-card-modern h3 { font-family: 'Unbounded', sans-serif; font-size: 20px; margin-bottom: 12px; color: #fff; }
        .donate-price-modern { font-family: 'Unbounded', sans-serif; font-size: 18px; color: var(--acc); margin-bottom: 25px; font-weight: 900; }
        .donate-features-modern { list-style: none; text-align: left; margin-bottom: 25px; flex-grow: 1; }
        .donate-features-modern li { margin-bottom: 10px; color: #cbd5e1; font-size: 13px; display: flex; align-items: flex-start; gap: 8px; }
        .donate-features-modern li::before { content: '✓'; color: var(--acc); font-weight: bold; flex-shrink: 0; }
        
        .vortex-amount-box { margin-bottom: 20px; display: flex; background: rgba(0,0,0,0.4); border: 1px solid var(--border); border-radius: 12px; padding: 10px 14px; align-items: center; justify-content: space-between; }
        .vortex-amount-box span { font-size: 11px; color: var(--text-muted); font-weight: bold; letter-spacing: 1px; }
        .vortex-input { width: 50%; background: transparent; border: none; color: #fff; font-family: 'Unbounded', sans-serif; font-size: 14px; text-align: right; outline: none; }
        .btn-buy-modern { width: 100%; background: rgba(255, 255, 255, 0.04); color: #fff; border: 1px solid rgba(255, 255, 255, 0.1); padding: 14px; border-radius: 12px; font-family: 'Unbounded', sans-serif; font-size: 11px; font-weight: 900; cursor: pointer; transition: 0.3s; letter-spacing: 1px; }
        .btn-buy-modern:hover { transform: scale(1.02); background: var(--acc); color: #020406; border-color: transparent; box-shadow: 0 10px 20px var(--acc-glow); }

        .grid-contacts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 30px; }
        .contact-card { background: var(--panel); border: 1px solid var(--border); border-radius: 28px; padding: 40px; display: flex; align-items: center; gap: 30px; text-decoration: none; color: #fff; transition: 0.3s; backdrop-filter: blur(15px); }
        .contact-card:hover { border-color: var(--acc); transform: translateX(5px); box-shadow: 0 15px 30px var(--acc-glow); }
        .contact-icon { font-size: 40px; }
        .contact-info h3 { font-family: 'Unbounded', sans-serif; font-size: 18px; margin-bottom: 5px; }
        .contact-info p { color: var(--text-muted); font-size: 14px; }

